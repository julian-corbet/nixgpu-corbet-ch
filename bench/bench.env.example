# bench.env — the bench's own config. Copy to bench.env and fill in values
# for YOUR cluster; nothing in this repo ships a real endpoint, namespace, or
# model name. `run-bench.sh` sources this file with `set -a` (see its top),
# so every variable below becomes an exported shell variable.
#
# There is no default here that points at a live system — a value left at
# its placeholder will fail loudly (curl/kubectl errors), not silently pass.

# ---------------------------------------------------------------------------
# Cluster access
# ---------------------------------------------------------------------------

# kubectl context to use. Empty = whatever `kubectl config current-context`
# already resolves to (fine for an in-cluster Job using its ServiceAccount).
KCTX=""

# The ONE namespace every bench-created object lives in. run-bench.sh never
# reads or writes any other namespace except via the read-only telemetry/
# OpenAI-door HTTP calls below and read-only `kubectl get events`/`get pods`
# against nodes for the invariant checks.
#
# Deliberately an obviously-fake placeholder: the bench creates AND sweeps
# (label-scoped deletes) objects in this namespace, so it must never default
# to anything that could exist on a real cluster. Pick a dedicated,
# bench-only namespace and set it here yourself.
NAMESPACE="replace-me-bench-only-namespace"

# ---------------------------------------------------------------------------
# Telemetry (see bench/README.md for the exact JSON shape expected)
# ---------------------------------------------------------------------------

TELEMETRY_URL="https://telemetry.example.invalid/status"

# ---------------------------------------------------------------------------
# OpenAI-compatible door (nixllm's broker, or any compatible server)
# ---------------------------------------------------------------------------

OPENAI_URL="https://llm-door.example.invalid/v1"
OPENAI_API_KEY="" # usually empty for an in-cluster/LAN-only door

# ---------------------------------------------------------------------------
# Label / priority vocabulary
#
# These match nixgpu's own module defaults (priority-ladder, device-tokens,
# pressure-watcher) — override only if your environment renamed them.
# ---------------------------------------------------------------------------

MANAGED_LABEL_KEY="nixgpu.corbet.ch/managed"
ENGINE_LABEL_KEY="nixgpu.corbet.ch/engine"
ENGINE_VCN_VALUE="vcn"
DEVICE_TOKEN_COMPUTE="devic.es/rocm-compute"
DEVICE_TOKEN_VCN="devic.es/vcn"
PRIORITY_DESKTOP="gpu-desktop"
PRIORITY_INTERACTIVE="gpu-interactive"
PRIORITY_BESTEFFORT="gpu-besteffort"

# ---------------------------------------------------------------------------
# Card geometry
#
# Informational fallback only — every scenario prefers TELEMETRY's
# vram_total when present. Used to size synthetic tenants sensibly when
# picking your own S1_TENANT_*_GIB / S2_*_GIB values below.
# ---------------------------------------------------------------------------

CARD_VRAM_GIB=16

# ---------------------------------------------------------------------------
# vram-hog image — see tenants/vram-hog.yaml for exactly what it needs
# (python3 + a ROCm-enabled torch build).
# ---------------------------------------------------------------------------

HSA_GFX_VERSION="10.3.0"  # ROCm arch override for hog pods — match your other GPU pods
HOG_IMAGE="example-registry.invalid/rocm-torch-allocator:latest"

# ---------------------------------------------------------------------------
# S1 — co-residence: three tenants sized to fit together comfortably under
# CARD_VRAM_GIB. Priorities are deliberately mixed (S1 asserts nothing is
# evicted even though priorities differ, as long as everything fits).
# ---------------------------------------------------------------------------

S1_TENANT_A_GIB=1
S1_TENANT_A_PRIORITY="${PRIORITY_BESTEFFORT}"
S1_TENANT_B_GIB=6
S1_TENANT_B_PRIORITY="${PRIORITY_INTERACTIVE}"
S1_TENANT_C_GIB=7
S1_TENANT_C_PRIORITY="${PRIORITY_BESTEFFORT}"

# ---------------------------------------------------------------------------
# S2 — contention: a best-effort hog sized to fill the card, then an
# interactive-priority tenant that cannot fit alongside it. Keep
# HOG + INTERACTIVE > CARD_VRAM_GIB so the fit genuinely fails without a
# yield.
# ---------------------------------------------------------------------------

S2_HOG_GIB=15
S2_INTERACTIVE_GIB=7

# ---------------------------------------------------------------------------
# S3 — swap + TTL
# ---------------------------------------------------------------------------

MODEL_COLD="small-cold-model" # known to the door, NOT expected resident at test start
IDLE_TTL_S=90 # set to (or below) your real front/broker idle TTL; smaller = faster bench run

# ---------------------------------------------------------------------------
# S4 — same-model concurrency
# ---------------------------------------------------------------------------

MODEL_CONCURRENCY="small-chat-model"
CONCURRENT_REQUESTS=8
COMPLETION_PROMPT="Write one sentence about weather."
COMPLETION_MAX_TOKENS=64
# HTTP gate for BOTH the serial and the concurrent phase (and calibrate's
# serial baseline): at least this many of the CONCURRENT_REQUESTS requests
# must return 200 per phase, or the throughput comparison is void and the
# scenario FAILs. Default: all of them.
S4_MIN_OK_COUNT="${CONCURRENT_REQUESTS}"

# ---------------------------------------------------------------------------
# S5 — multi-model co-residency: two DIFFERENT small models expected to fit
# and stay resident together.
# ---------------------------------------------------------------------------

MODEL_SMALL_A="small-chat-model"
MODEL_SMALL_B="small-embedding-model"
# Co-residency is inferred from the vram_used plateau (telemetry is
# pod-level, never model-level): loading B on top of a still-resident A must
# raise vram_used by at least this many MiB above A's plateau. Set it below
# B's expected weight footprint but well above measurement noise.
S5_CORESIDENCY_FLOOR_MIB=256

# ---------------------------------------------------------------------------
# S9 — idempotent batch driver
# ---------------------------------------------------------------------------

BATCH_JOB_COUNT=10
# Must contain BOTH a shell AND a kubectl binary — each item pod reads/writes
# its own completion marker in the S9 ledger ConfigMap via `kubectl` itself
# (see run-bench.sh's s9_batch_idempotent). No GPU access required. The
# pressure-watcher module's own default image (bitnami/kubectl) satisfies
# this; busybox/alpine alone do NOT (no kubectl).
BATCH_ITEM_IMAGE="bitnami/kubectl:latest"
BATCH_ITEM_WORK_SECONDS=8 # simulated "unit of work" duration per item
# The S9 force-hog is sized from LIVE telemetry as
# (vram_total - vram_used) + this margin, in GiB, so it genuinely cannot fit
# and a preemption actually happens (S9 SKIPs, not passes, when no
# resubmission was ever observed).
S9_FORCE_HOG_MARGIN_GIB=2

# ---------------------------------------------------------------------------
# S10 — MoE partial offload
# ---------------------------------------------------------------------------

MODEL_MOE="oversized-moe-model"

# ---------------------------------------------------------------------------
# S6 — persistent VCN transcoder (see tenants/vcn-transcoder.yaml)
# ---------------------------------------------------------------------------

VCN_IMAGE="example-registry.invalid/vaapi-ffmpeg:latest"
VAAPI_RENDER_NODE="/dev/dri/renderD128"
VCN_STALL_THRESHOLD_S=45 # no fresh "TRANSCODE LOOP" / progress log line for this long = stalled

# ---------------------------------------------------------------------------
# S7 — wake probe (an ondemand-front-fronted app)
# ---------------------------------------------------------------------------

PROBE_URL="https://waking-app.example.invalid/"
WAITING_PAGE_MARKER="one honest waiting page" # must appear ONLY on the waiting page, never on the real app or a real 404
PROBE_INTERVAL_S=1
PROBE_GRACE_S=5 # a probe may go unanswered (ANY curl failure: refused/timeout/DNS/TLS/reset) for at most this long of WALL-CLOCK, right at cold-start
# Budget for OPAQUE errors: answered non-2xx responses WITHOUT the
# waiting-page marker (a raw 502/503 leaking past the front). Every one is
# counted; more than this many fails S7. 0 = the front never leaks.
S7_OPAQUE_BUDGET=0

# ---------------------------------------------------------------------------
# Budgets — contract numbers where CONTRACT.md states one, otherwise a
# conservative default the calibrate step is meant to replace.
# ---------------------------------------------------------------------------

COLD_WAKE_BUDGET_S=10 # contract: model load "~2-3s" from cache -> generous default
EVICTION_BUDGET_S=60 # B2: wall time from pressure applied to victim scaled to 0
OOM_RETRY_WINDOW_S=90 # a pod may CrashLoopBackOff for at most this long during a forced eviction
S11_CHAOS_DURATION_S=600
TICK_S=5 # bench poll interval; keep <= your pressure-watcher's own tickSeconds

# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------

OUTPUT_DIR="./bench-results"
CALIBRATE_FILE="./bench-results/baseline.json"
